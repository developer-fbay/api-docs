    {
      "name": "GoDaddy API",
      "item": [
        {
          "name": "Get All Domains",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Get credentials from environment",
                  "var apiKey = pm.environment.get(\"godaddy_api_key\");",
                  "var apiSecret = pm.environment.get(\"godaddy_api_secret\");",
                  "",
                  "// Set authorization header in SSO key format",
                  "pm.request.headers.add({",
                  "    key: 'Authorization',",
                  "    value: 'sso-key ' + apiKey + ':' + apiSecret",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "console.log(\"Response:\", pm.response.json());",
                  "console.log(\"Number of domains:\", pm.response.json().length);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{godaddy_base_url}}/v1/domains?limit=100",
              "host": [
                "{{godaddy_base_url}}"
              ],
              "path": [
                "v1",
                "domains"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "100",
                  "description": "Number of results per page"
                },
                {
                  "key": "marker",
                  "value": "{{godaddy_marker}}",
                  "description": "Domain name for pagination (optional)",
                  "disabled": true
                }
              ]
            },
            "description": "Get all domains with pagination"
          },
          "response": []
        }
      ]
    }
